<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.ArogyaNidhi" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/cyan_mid</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/tint_cyan_bg</item>
        <item name="colorOnPrimaryContainer">@color/cyan_darker</item>

        <item name="colorSecondary">@color/cyan_primary</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">@color/cyan_deep</item>
        <item name="android:navigationBarColor">@color/bg_card</item>

        <!-- Optional: enable when you add Inter font files to res/font/
             <item name="android:fontFamily">@font/inter</item> -->

        <item name="materialButtonStyle">@style/Widget.ArogyaNidhi.Button</item>
        <item name="textInputStyle">@style/Widget.ArogyaNidhi.TextInputLayout</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.ArogyaNidhi.Splash" parent="Theme.ArogyaNidhi">
        <item name="android:statusBarColor">@color/cyan_primary</item>
        <item name="android:windowBackground">@drawable/bg_gradient_cyan</item>
    </style>

    <!-- Button -->
    <style name="Widget.ArogyaNidhi.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.ArogyaNidhi.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/cyan_mid</item>
        <item name="strokeWidth">1.5dp</item>
    </style>

    <!-- TextInputLayout -->
    <style name="Widget.ArogyaNidhi.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/cyan_mid</item>
        <item name="hintTextColor">@color/cyan_deep</item>
    </style>

</resources>
