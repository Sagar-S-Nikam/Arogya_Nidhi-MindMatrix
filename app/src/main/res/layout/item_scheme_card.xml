<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_scheme_card"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/tvSchemeName"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="@color/cyan_darker"
        android:textSize="14.5sp" android:textStyle="bold"/>

    <TextView
        android:id="@+id/tvBenefit"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_benefit_pill"
        android:paddingStart="10dp" android:paddingEnd="10dp"
        android:paddingTop="3dp" android:paddingBottom="3dp"
        android:textColor="@color/success"
        android:textSize="11sp" android:textStyle="bold"/>

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/text_primary"
        android:textSize="12.5sp"
        android:lineSpacingMultiplier="1.45"/>

    <TextView
        android:id="@+id/tvWhyQualify"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="@color/text_secondary"
        android:textSize="11.5sp"
        android:textStyle="italic"/>

    <TextView
        android:id="@+id/tvViewDocs"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="2dp"
        android:text="📑 View required documents →"
        android:textColor="@color/cyan_deep"
        android:textSize="12sp" android:textStyle="bold"/>
</LinearLayout>
