<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <LinearLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_cyan"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp" android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@android:color/white" />

        <LinearLayout
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_marginStart="8dp" android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Your Results"
                android:textColor="@android:color/white"
                android:textSize="15sp" android:textStyle="bold"/>
            <TextView
                android:id="@+id/tvResultSub"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#E0FFFFFF"
                android:textSize="11sp"/>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent" android:layout_height="0dp"
        android:padding="18dp"
        app:layout_constraintTop_toBottomOf="@id/appBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Banner -->
            <LinearLayout
                android:id="@+id/resultBanner"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@drawable/bg_result_success"
                android:gravity="center" android:orientation="vertical" android:padding="18dp">
                <TextView
                    android:id="@+id/tvBannerIcon"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="✓"
                    android:textColor="@android:color/white" android:textSize="34sp"/>
                <TextView
                    android:id="@+id/tvBannerTitle"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/great_news"
                    android:textColor="@android:color/white"
                    android:textSize="18sp" android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvBannerDesc"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#E6FFFFFF"
                    android:textSize="12sp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSchemes"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:nestedScrollingEnabled="false" />

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="14dp" android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSave"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/btn_primary_gradient"
                    android:backgroundTint="@null"
                    android:text="@string/save_result"
                    android:textColor="@android:color/white"
                    app:cornerRadius="14dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDownload"
                    style="@style/Widget.ArogyaNidhi.Button.Outlined"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_marginStart="10dp" android:layout_weight="1"
                    android:text="@string/download"
                    android:textColor="@color/cyan_deep"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRetake"
                style="@style/Widget.ArogyaNidhi.Button.Outlined"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/retake_quiz"
                android:textColor="@color/text_secondary"
                app:strokeColor="@color/border"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
